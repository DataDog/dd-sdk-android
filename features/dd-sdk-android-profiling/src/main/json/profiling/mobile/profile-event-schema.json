{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "profiling/mobile/profile-event-schema.json",
  "title": "MobileProfileEvent",
  "description": "Schema of the Mobile SDK Profile Event metadata.",
  "allOf": [
    {
      "$ref": "../_common-schema.json"
    },
    {
      "type": "object",
      "properties": {
        "error": {
          "type": "object",
          "description": "Error properties.",
          "required": ["id"],
          "properties": {
            "id": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Array of error IDs.",
              "readOnly": true
            }
          },
          "readOnly": true
        }
      }
    }
  ]
}
